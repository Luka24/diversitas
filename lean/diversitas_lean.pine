//@version=6
indicator("Diversitas Lean", shorttitle="DIV-LEAN", overlay=true, max_bars_back=5000, max_labels_count=50, max_lines_count=50)

// ============================================================================
// DIVERSITAS LEAN — MINIMAL MODEL
//
// The "strip it to the bones" experiment. Keeps only what proved valuable
// across the whole project:
//   - Kijun trackline (direction)
//   - 50 MA (trend confirmation) + 200 MA (regime filter)
//   - Blow-off top detection (exit)
//   - Vol shock (exit)
//   - Anti-churn state machine (signal hygiene, not complexity)
//   - Optional vol-targeted sizing (additive, off the signal path)
//
// Deliberately DROPPED: conviction score, ADX, market structure,
// weekly gate, on-chain pipe, macro pipe.
//
// No request.security on BTC (BTC filter optional, off by default) —
// the core model is fully self-contained on daily OHLCV.
// ============================================================================

// === TRACKLINE ===
trackPeriod = input.int(75, "Trackline Period", minval=20, maxval=120, group="Core")
trackBuf = input.float(3.0, "Trackline Buffer %", minval=0.0, maxval=5.0, step=0.25, group="Core")

// === MOVING AVERAGES ===
maMedLen = input.int(50, "Trend MA (medium)", minval=20, maxval=100, group="Moving Averages", tooltip="Price must be above this for a BULL. Confirms medium-term trend.")
maLongLen = input.int(200, "Regime MA (long)", minval=100, maxval=300, group="Moving Averages", tooltip="Bear-market filter. No entries when price is below a falling long MA.")
maSlope = input.int(5, "Regime MA Slope Lookback", minval=1, maxval=20, group="Moving Averages")

// === EXITS ===
blowoffDist = input.float(25.0, "Blow-off Distance %", minval=10.0, maxval=40.0, step=1.0, group="Exits", tooltip="Exit if price is this % above trackline AND RSI > 80.")
rsiLen = input.int(14, "RSI Length", group="Exits")
volShockMul = input.float(1.5, "Vol Shock Multiplier", minval=1.2, maxval=3.0, step=0.1, group="Exits")
volLookback = input.int(20, "Vol Lookback Days", minval=5, maxval=60, group="Exits")

// === RANGE FILTER (kills sideways chop) ===
trackSlopeBars = input.int(10, "Trackline Slope Lookback", minval=1, maxval=30, group="Range Filter", tooltip="BULL requires the trackline to be rising over this many bars. In a range the Kijun trackline goes flat, so this blocks sideways whipsaws.")
minDistEntry = input.float(0.0, "Min Entry Distance % (extra)", minval=0.0, maxval=15.0, step=0.5, group="Range Filter", tooltip="Optional: require price this % above trackline to enter (on top of the buffer). 0 = off.")

// === ANTI-CHURN ===
confirmBars = input.int(3, "Confirmation Bars", minval=1, maxval=5, group="Anti-Churn")
reentryHold = input.int(15, "Re-entry Hold Lock", minval=1, maxval=30, group="Anti-Churn")
exitGraceBars = input.int(3, "Exit Grace", minval=1, maxval=5, group="Anti-Churn")

// === SIZING (optional, additive — never changes signal timing) ===
useVolSizing = input.bool(true, "Volatility-Targeted Sizing", group="Sizing")
targetVol = input.float(50.0, "Target Vol %", minval=20.0, maxval=100.0, step=5.0, group="Sizing")

// === OPTIONAL ===
useBtcFilter = input.bool(false, "BTC Filter (for altcoins)", group="Optional", tooltip="Off by default. Turn on for altcoins: requires BTC above its 50 EMA.")

// === DISPLAY ===
showDots = input.bool(true, "Show Dots", group="Display")
showBG = input.bool(true, "Show Background", group="Display")
showLabels = input.bool(true, "Show Labels", group="Display")

// ============================================================================
// CORE INDICATORS
// ============================================================================

trackHigh = ta.highest(high, trackPeriod)
trackLow = ta.lowest(low, trackPeriod)
trackline = (trackHigh + trackLow) / 2.0
trackRising = trackline > trackline[1]
trackRisingWindow = trackline > trackline[trackSlopeBars]
bufAmt = trackline * (trackBuf / 100.0)
aboveTL = close > (trackline + bufAmt)
belowTL = close < (trackline - bufAmt)
distPct = (close - trackline) / trackline * 100

maMed = ta.sma(close, maMedLen)
maLong = ta.sma(close, maLongLen)
maLongRising = maLong > maLong[maSlope]
maLongFalling = maLong < maLong[maSlope]
aboveMaLong = close > maLong

// Regime: blocked only in a confirmed bear (below a falling long MA)
bearRegime = not aboveMaLong and maLongFalling
regimeOK = not bearRegime

rsiVal = ta.rsi(close, rsiLen)

// Volatility
logRet = math.log(close / close[1])
dailyStd = ta.stdev(logRet, volLookback)
annualVol = dailyStd * math.sqrt(365) * 100

// Optional BTC filter
btcClose = request.security("COINBASE:BTCUSD", "D", close)
btcEMA50 = request.security("COINBASE:BTCUSD", "D", ta.ema(close, 50))
btcFilterOK = not useBtcFilter or (btcClose > btcEMA50)

// ============================================================================
// ENTRY / EXIT CONDITIONS
// ============================================================================

// BULL entry: above trackline + above medium MA + trackline RISING (range filter)
//   + optional extra distance + not in bear regime + (optional) BTC OK
distEntryOK = distPct >= (trackBuf + minDistEntry)
bullCondition = aboveTL and close > maMed and trackRisingWindow and distEntryOK and regimeOK and btcFilterOK

// Exits
trendBreak = belowTL
blowoff = distPct > blowoffDist and rsiVal > 80
volShock = annualVol > ta.sma(annualVol, 50) * volShockMul and belowTL

// ============================================================================
// STATE MACHINE — strict BULL/BEAR alternation + anti-churn
// ============================================================================

greenDot = bullCondition
redDot = belowTL

var int signalState = 3   // 1 = BULL, 3 = BEAR
var int barsSinceSignal = 999
var int belowCount = 0
var int bullHoldCount = 0
barsSinceSignal := barsSinceSignal + 1

if belowTL
    belowCount := belowCount + 1
else
    belowCount := 0
if bullCondition
    bullHoldCount := bullHoldCount + 1
else
    bullHoldCount := 0

// BEAR exits (only when currently BULL) — immediate
if signalState == 1
    if trendBreak and belowCount >= exitGraceBars
        signalState := 3
        barsSinceSignal := 0
    else if blowoff
        signalState := 3
        barsSinceSignal := 0
    else if volShock
        signalState := 3
        barsSinceSignal := 0

// BULL entry (only when currently BEAR) — confirmation + re-entry lock
if signalState == 3
    if bullCondition and bullHoldCount >= confirmBars and barsSinceSignal >= reentryHold
        signalState := 1
        barsSinceSignal := 0

var int prevSignal = 3
signalChanged = signalState != prevSignal
prevSignal := signalState

// Display state for background (BULL / HEDGED / BEAR)
var int displayState = 3
if belowTL and belowCount >= exitGraceBars
    displayState := 3
else if aboveTL and bullCondition
    displayState := 1
else if aboveTL and not bullCondition
    displayState := 2

// ============================================================================
// SIZING LAYER (additive — applied after signal)
// ============================================================================

volScale = (useVolSizing and annualVol > 0) ? math.min(1.0, targetVol / annualVol) : 1.0
targetAlloc = signalState == 1 ? math.round(math.max(0.0, math.min(100.0, 100.0 * volScale))) : 0

// ============================================================================
// PLOTS
// ============================================================================

plot(trackline, "Trackline", color=trackRising ? color.new(#00E676, 0) : color.new(#FF5252, 0), linewidth=3)
plot(maMed, "Trend MA", color=color.new(#42A5F5, 30), linewidth=1)
plot(maLong, "Regime MA", color=maLongRising ? color.new(#00C853, 40) : color.new(#FF1744, 40), linewidth=2)
plot(targetAlloc, "Allocation %", color=color.new(#42A5F5, 0), linewidth=2, style=plot.style_stepline, display=display.pane + display.data_window)

plotshape(showDots and greenDot, title="Green Dot", style=shape.circle, location=location.belowbar, color=color.new(#00E676, 0), size=size.tiny)
plotshape(showDots and redDot, title="Red Dot", style=shape.circle, location=location.abovebar, color=color.new(#FF5252, 0), size=size.tiny)

var color bg = na
if showBG
    bg := displayState == 1 ? color.new(#00C853, 92) : displayState == 2 ? color.new(#FFD600, 93) : color.new(#FF1744, 94)
else
    bg := na
bgcolor(bg)

if showLabels and signalChanged
    if signalState == 1
        label.new(bar_index, low, "BULL", style=label.style_label_up, color=color.new(#00C853, 0), textcolor=color.white, size=size.normal)
    else
        label.new(bar_index, high, "BEAR", style=label.style_label_down, color=color.new(#FF1744, 0), textcolor=color.white, size=size.normal)

// ============================================================================
// STATUS TABLE
// ============================================================================

var table tbl = table.new(position.top_right, 2, 7, bgcolor=color.new(#0D1117, 0), border_width=1, border_color=color.new(#30363D, 0))

if barstate.islast
    sigStr = signalState == 1 ? "BULL" : "BEAR"
    sigClr = signalState == 1 ? color.new(#00C853, 0) : color.new(#FF1744, 0)
    dispStr = displayState == 1 ? "BULL" : displayState == 2 ? "HEDGED" : "BEAR"
    dispClr = displayState == 1 ? color.new(#00C853, 0) : displayState == 2 ? color.new(#FFD600, 0) : color.new(#FF1744, 0)

    table.cell(tbl, 0, 0, "DIVERSITAS LEAN", text_color=color.white, text_size=size.normal, bgcolor=color.new(#161B22, 0))
    table.cell(tbl, 1, 0, sigStr, text_color=color.white, text_size=size.normal, bgcolor=sigClr)

    table.cell(tbl, 0, 1, "Regime", text_color=color.gray, text_size=size.small)
    table.cell(tbl, 1, 1, dispStr, text_color=dispClr, text_size=size.small)

    table.cell(tbl, 0, 2, "Allocation", text_color=color.gray, text_size=size.small)
    allClr = targetAlloc >= 75 ? color.new(#00E676, 0) : targetAlloc >= 40 ? color.new(#EF9F27, 0) : targetAlloc > 0 ? color.new(#FFD600, 0) : color.new(#FF5252, 0)
    table.cell(tbl, 1, 2, str.tostring(targetAlloc) + "%", text_color=allClr, text_size=size.small)

    table.cell(tbl, 0, 3, "Regime MA", text_color=color.gray, text_size=size.small)
    maStr = bearRegime ? "BEAR (blocked)" : aboveMaLong ? "ABOVE" : "BELOW"
    maClr = bearRegime ? color.new(#FF1744, 0) : aboveMaLong ? color.new(#00E676, 0) : color.new(#EF9F27, 0)
    table.cell(tbl, 1, 3, maStr, text_color=maClr, text_size=size.small)

    table.cell(tbl, 0, 4, "Trend MA", text_color=color.gray, text_size=size.small)
    tmClr = close > maMed ? color.new(#00E676, 0) : color.new(#FF5252, 0)
    table.cell(tbl, 1, 4, close > maMed ? "ABOVE" : "BELOW", text_color=tmClr, text_size=size.small)

    table.cell(tbl, 0, 5, "Trackline", text_color=color.gray, text_size=size.small)
    tClr = trackRisingWindow ? color.new(#00E676, 0) : color.new(#FF5252, 0)
    trackStateStr = trackRisingWindow ? "RISING" : "FLAT/FALLING"
    table.cell(tbl, 1, 5, str.tostring(trackline, "#.00") + " " + trackStateStr, text_color=tClr, text_size=size.small)

    table.cell(tbl, 0, 6, "Price vs TL", text_color=color.gray, text_size=size.small)
    dClr = distPct > 0 ? color.new(#00E676, 0) : color.new(#FF5252, 0)
    table.cell(tbl, 1, 6, (distPct > 0 ? "+" : "") + str.tostring(distPct, "#.1") + "%", text_color=dClr, text_size=size.small)

// ============================================================================
// ALERTS
// ============================================================================

alertcondition(signalChanged and signalState == 1, title="BULL", message="DIVERSITAS LEAN: BULL - {{ticker}} at {{close}}")
alertcondition(signalChanged and signalState == 3, title="BEAR", message="DIVERSITAS LEAN: BEAR - {{ticker}} at {{close}}")
alertcondition(blowoff, title="BLOW-OFF", message="DIVERSITAS LEAN: BLOW-OFF exit - {{ticker}} at {{close}}")
alertcondition(volShock, title="VOL SHOCK", message="DIVERSITAS LEAN: VOL SHOCK exit - {{ticker}} at {{close}}")
